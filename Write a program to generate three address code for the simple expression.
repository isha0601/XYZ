C Program to Generate Three Address Code (TAC)
This program generates Three Address Code for a simple arithmetic expression.

Program
#include<stdio.h>
#include<string.h>

int main()
{
    char exp[20];
    char op[10], arg1[10], arg2[10];
    int i = 0, j = 0, k = 0;
    int temp = 1;

    printf("Enter Expression: ");
    scanf("%s", exp);

    printf("\nThree Address Code:\n");

    while(exp[i] != '\0')
    {
        if(exp[i] == '+' || exp[i] == '-' ||
           exp[i] == '*' || exp[i] == '/')
        {
            op[k] = exp[i];

            arg1[k] = exp[i-1];
            arg2[k] = exp[i+1];

            printf("t%d = %c %c %c\n",
                   temp,
                   arg1[k],
                   op[k],
                   arg2[k]);

            exp[i+1] = 't';

            temp++;
            k++;
        }

        i++;
    }

    return 0;
}
Sample Input
a+b*c-d
Sample Output
Three Address Code:
t1 = b * c
t2 = a + t
t3 = t - d
Another Example
Input
a+b
Output
Three Address Code:
t1 = a + b
Compilation & Execution
Compile
gcc tac.c -o tac
Run
./tac
