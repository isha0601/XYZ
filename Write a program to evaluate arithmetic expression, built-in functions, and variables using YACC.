YACC Program to Evaluate Arithmetic Expressions, Built-in Functions and Variables
This program evaluates:

Arithmetic expressions (+ , - , * , /)
Variables
Built-in functions like sin(), cos(), sqrt()
1. LEX File (calc.l)
%{
#include "y.tab.h"
#include <math.h>
%}

%%

[0-9]+      { yylval = atoi(yytext); return NUMBER; }

[a-zA-Z]+   {
                if(strcmp(yytext,"sin")==0) return SIN;
                if(strcmp(yytext,"cos")==0) return COS;
                if(strcmp(yytext,"sqrt")==0) return SQRT;

                return VARIABLE;
            }

[\t ]       ;

\n          return '\n';

.           return yytext[0];

%%

int yywrap()
{
    return 1;
}
2. YACC File (calc.y)
%{
#include<stdio.h>
#include<stdlib.h>
#include<math.h>

int yylex();
void yyerror(char *s);

int vars[26];
%}

%token NUMBER VARIABLE
%token SIN COS SQRT

%left '+' '-'
%left '*' '/'

%%

statement:
        statement expr '\n'
        |
        ;

expr:
        NUMBER                  { printf("Result = %d\n", $1); }

      | VARIABLE '=' expr       {
                                    vars[$1-'a'] = $3;
                                    printf("Assigned\n");
                                }

      | VARIABLE                {
                                    $$ = vars[$1-'a'];
                                    printf("Value = %d\n", $$);
                                }

      | expr '+' expr           {
                                    $$ = $1 + $3;
                                    printf("Result = %d\n", $$);
                                }

      | expr '-' expr           {
                                    $$ = $1 - $3;
                                    printf("Result = %d\n", $$);
                                }

      | expr '*' expr           {
                                    $$ = $1 * $3;
                                    printf("Result = %d\n", $$);
                                }

      | expr '/' expr           {
                                    $$ = $1 / $3;
                                    printf("Result = %d\n", $$);
                                }

      | SIN '(' expr ')'        {
                                    $$ = sin($3);
                                    printf("sin = %d\n", $$);
                                }

      | COS '(' expr ')'        {
                                    $$ = cos($3);
                                    printf("cos = %d\n", $$);
                                }

      | SQRT '(' expr ')'       {
                                    $$ = sqrt($3);
                                    printf("sqrt = %d\n", $$);
                                }

      | '(' expr ')'            {
                                    $$ = $2;
                                }
      ;

%%

int main()
{
    printf("Enter Expression:\n");
    yyparse();
    return 0;
}

void yyerror(char *s)
{
    printf("Error: %s\n", s);
}
Sample Input
5+3
a=10
a+5
sqrt(16)
sin(0)
Sample Output
Result = 8
Assigned
Result = 15
sqrt = 4
sin = 0
Compilation Commands
Step 1: Generate YACC File
yacc -d calc.y
Step 2: Generate LEX File
lex calc.l
Step 3: Compile
gcc y.tab.c lex.yy.c -o calc -ll -lm
Step 4: Run
./calc
